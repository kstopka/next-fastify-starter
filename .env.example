# ─────────────────────────────────────────────────────────────
# .env — Konfiguracja projektu
#
# Skopiuj do .env:  cp .env.example .env
# Lub uruchom:      ./setup.sh   (skopiuje automatycznie)
#
# Dev:   docker compose --file=docker-compose.yml up -d
# Prod:  docker compose --file=docker-compose.production.yml up -d
# ─────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────
HOST=db
PORT=5432
SCHEME=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# ─── Backend ─────────────────────────────────────────────────
#scheme://user:password@host:port/database?params
DATABASE_URL=postgres://postgres:postgres@db:5432/app_db
JWT_SECRET=change_me_in_production
